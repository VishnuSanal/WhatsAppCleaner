<?xml version="1.0" encoding="utf-8"?>

<!--
    API     Android Version     Emulator / Real Device
    24      7.0                          E
    25      7.1                          *
    26      8.0                          *
    27      8.1                          *
    28      9                            *
    29      10                           *
                                                        File    SAF
    30      11                           *
    31      12                           *
    32      12                           *
    33      13                           *
    34      14                           *
    35      15                           R                *      *
    36      16                           *
    37      17                           E                *      *
-->

<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
        API <= 29 uses the direct File API (fast) for all build variants; legacy external
        storage opts API 29 out of scoped storage so the File API can reach
        Android/media/com.whatsapp. On API >= 30 the release/debug builds keep using the File API
        via All Files Access (declared only in those source sets); the Play build falls back to SAF.
    -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/recycling"
        android:label="@string/app_name"
        android:requestLegacyExternalStorage="true"
        android:roundIcon="@drawable/recycling_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.WhatsAppCleaner"
        tools:targetApi="31">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.WhatsAppCleaner"
            tools:ignore="LockedOrientationActivity">
            <!-- TODO: support orientations -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.provider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/provider_paths" />
        </provider>
    </application>

</manifest>